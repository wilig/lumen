// In-language testing. Import, assert, and call summary() from main:
//
//     import std/test
//     fn main(): i32 io {
//         test.eq(1 + 1, 2, "addition")
//         test.is_true("hi" == "hi", "string eq")
//         return test.summary()
//     }
//
// Counter state is module-level (top-level `var`). Summary prints a
// one-line report and returns the failure count so
// `return test.summary()` from main gives the right exit code.

import std/io

var pass_count: i32 = 0
var fail_count: i32 = 0

fn eq<T>(actual: T, expected: T, label: string): unit io {
    if actual == expected {
        io.println("  ok  ${label}")
        pass_count = pass_count + 1
    } else {
        io.println("  FAIL  ${label}: expected ${expected}, got ${actual}")
        fail_count = fail_count + 1
    }
}

fn ne<T>(actual: T, expected: T, label: string): unit io {
    if actual != expected {
        io.println("  ok  ${label}")
        pass_count = pass_count + 1
    } else {
        io.println("  FAIL  ${label}: both values = ${actual}")
        fail_count = fail_count + 1
    }
}

fn is_true(cond: bool, label: string): unit io {
    if cond {
        io.println("  ok  ${label}")
        pass_count = pass_count + 1
    } else {
        io.println("  FAIL  ${label}: expected true")
        fail_count = fail_count + 1
    }
}

fn is_false(cond: bool, label: string): unit io {
    if cond {
        io.println("  FAIL  ${label}: expected false")
        fail_count = fail_count + 1
    } else {
        io.println("  ok  ${label}")
        pass_count = pass_count + 1
    }
}

fn fail(label: string): unit io {
    io.println("  FAIL  ${label}")
    fail_count = fail_count + 1
}

// Prints a summary and returns the number of failures.
fn summary(): i32 io {
    let total = pass_count + fail_count
    if fail_count == 0 {
        io.println("")
        io.println("${pass_count}/${total} passed")
    } else {
        io.println("")
        io.println("${pass_count}/${total} passed, ${fail_count} failed")
    }
    return fail_count
}
