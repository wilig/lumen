// Result + ? operator chains, both ok and error paths.
import std/io

fn divide(a: i32, b: i32): Result<i32, string> {
    return if b == 0 { Err("div by zero") } else { Ok(a / b) }
}

fn pipeline(a: i32, b: i32, c: i32): Result<i32, string> {
    let x = divide(a, b)?
    let y = divide(x, c)?
    return Ok(y + 1)
}

fn main(): i32 io {
    match pipeline(100, 5, 4) {
        Ok(n) => io.println("ok=${n}"),
        Err(e) => io.println("err=${e}"),
    }
    match pipeline(100, 0, 4) {
        Ok(n) => io.println("ok=${n}"),
        Err(e) => io.println("err=${e}"),
    }
    match pipeline(100, 5, 0) {
        Ok(n) => io.println("ok=${n}"),
        Err(e) => io.println("err=${e}"),
    }
    return 0
}
