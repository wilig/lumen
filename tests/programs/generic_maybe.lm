// Generic sum type with Just/Nothing; exercises pointer + scalar payloads
// through the same monomorphizer.
import std/io

type Maybe<T> = | Nothing | Just { value: T }

fn unwrap_or<T>(m: Maybe<T>, default: T): T {
    return match m {
        Nothing => default,
        Just { value: v } => v,
    }
}

fn main(): i32 io {
    let mi: Maybe<i32> = Just { value: 99 }
    let ms: Maybe<string> = Just { value: "hi" }
    let mn: Maybe<i32> = Nothing
    io.println(unwrap_or(mi, 0))
    io.println(unwrap_or(ms, "fallback"))
    io.println(unwrap_or(mn, -1))
    return 0
}
