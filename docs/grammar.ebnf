(* Lumen — Formal Grammar (EBNF)                                             *)
(* Notation: { X } = zero or more X, [ X ] = optional X, | = alternation,    *)
(*           "..." = literal terminal, UPPER_CASE = token class.              *)

(* ========================================================================= *)
(* Top level                                                                  *)
(* ========================================================================= *)

module          = { import } , { item } ;

import          = "import" , module_path , [ "as" , IDENT ] ;
module_path     = IDENT , { "/" , IDENT } ;

item            = fn_decl | type_decl | extern_fn_decl
                | actor_decl | msg_handler_decl ;

(* ========================================================================= *)
(* Function declarations                                                      *)
(* ========================================================================= *)

fn_decl         = "fn" , IDENT , "(" , [ param_list ] , ")" ,
                  ":" , type , [ effect ] , block ;

extern_fn_decl  = "extern" , "fn" , IDENT , "(" , [ param_list ] , ")" ,
                  ":" , type , [ link_name ] ;

link_name       = "link" , STRING_LIT ;   (* C symbol: extern fn sqrt(...) link "lumen_sqrt" *)

param_list      = param , { "," , param } ;
param           = IDENT , ":" , type ;

effect          = "io" | "pure" ;    (* default: pure if omitted *)

(* ========================================================================= *)
(* Actor declarations                                                         *)
(* ========================================================================= *)

actor_decl      = "actor" , IDENT , "{" , [ field_list ] , "}" ;

msg_handler_decl = "msg" , IDENT , "." , IDENT ,
                   "(" , "self" , { "," , param } , ")" ,
                   ":" , type , block ;

(* ========================================================================= *)
(* Type declarations                                                          *)
(* ========================================================================= *)

type_decl       = "type" , IDENT , "=" , ( struct_body | sum_body ) ;

struct_body     = "{" , [ field_list ] , "}" ;
field_list      = field , { "," , field } , [ "," ] ;
field           = IDENT , ":" , type ;

sum_body        = [ "|" ] , variant , { "|" , variant } ;
variant         = IDENT , [ variant_payload ] ;
variant_payload = "{" , [ field_list ] , "}"
                | "(" , type , { "," , type } , ")" ;

(* ========================================================================= *)
(* Types                                                                      *)
(* ========================================================================= *)

type            = fn_ptr_type | tuple_type | named_type ;

fn_ptr_type     = "fn" , "(" , [ type , { "," , type } ] , ")" , ":" , type ;
tuple_type      = "(" , type , { "," , type } , ")" ;
named_type      = IDENT , [ "<" , type , { "," , type } , ">" ] ;

(* Built-in type names: i32, i64, u32, u64, f64, bool, string, bytes, unit.   *)
(* Generic built-ins: Option<T>, Result<T,E>, List<T>, Handle<T>.             *)

(* ========================================================================= *)
(* Statements and blocks                                                      *)
(* ========================================================================= *)

block           = "{" , { stmt } , [ tail_expr ] , "}" ;

stmt            = let_stmt | let_tuple_stmt | var_stmt | assign_stmt
                | expr_stmt | for_stmt | return_stmt ;

let_stmt        = "let" , IDENT , [ ":" , type ] , "=" , expr ;
let_tuple_stmt  = "let" , "(" , IDENT , { "," , IDENT } , ")" , "=" , expr ;
var_stmt        = "var" , IDENT , [ ":" , type ] , "=" , expr ;
assign_stmt     = IDENT , ( "=" | "+=" | "-=" | "*=" ) , expr ;
expr_stmt       = expr ;
for_stmt        = "for" , IDENT , "in" , expr , block ;
return_stmt     = "return" , [ expr ] ;

tail_expr       = expr ;   (* final expression is the block's value *)

(* ========================================================================= *)
(* Expressions (precedence from low to high)                                  *)
(* ========================================================================= *)

expr            = if_expr | match_expr | or_expr ;

if_expr         = "if" , expr , block , [ "else" , ( if_expr | block ) ] ;

match_expr      = "match" , expr , "{" , match_arm , { "," , match_arm } ,
                  [ "," ] , "}" ;
match_arm       = pattern , "=>" , expr ;

or_expr         = and_expr , { "||" , and_expr } ;
and_expr        = eq_expr , { "&&" , eq_expr } ;
eq_expr         = rel_expr , { ( "==" | "!=" ) , rel_expr } ;
rel_expr        = add_expr , { ( "<" | "<=" | ">" | ">=" ) , add_expr } ;
add_expr        = mul_expr , { ( "+" | "-" ) , mul_expr } ;
mul_expr        = cast_expr , { ( "*" | "/" | "%" ) , cast_expr } ;
cast_expr       = unary_expr , [ "as" , type ] ;
unary_expr      = ( "-" | "!" ) , unary_expr | postfix_expr ;

postfix_expr    = primary , { postfix } ;
postfix         = "." , IDENT                      (* field access *)
                | "." , INT_LIT                    (* tuple field: t.0, t.1 *)
                | "." , IDENT , call_args          (* method call  *)
                | call_args                        (* fn call      *)
                | "?" ;                            (* try propagation *)

call_args       = "(" , [ arg_list ] , ")" ;
arg_list        = arg , { "," , arg } ;
arg             = [ IDENT , ":" ] , expr ;

primary         = literal
                | IDENT
                | "(" , expr , ")"                 (* parenthesized expr *)
                | "(" , expr , "," , { expr , "," } , ")" (* tuple literal *)
                | block                            (* block expression *)
                | struct_lit                       (* struct/variant literal *)
                | lambda                           (* non-capturing lambda *)
                | spawn_expr | send_expr | ask_expr ;

struct_lit      = IDENT , "{" , [ field_init_list ] , "}" ;
field_init_list = ( field_init | spread ) , { "," , ( field_init | spread ) } , [ "," ] ;
field_init      = IDENT , ":" , expr ;
spread          = ".." , expr ;                    (* struct update: ..base *)

lambda          = "fn" , "(" , [ param_list ] , ")" , ":" , type , block ;

spawn_expr      = "spawn" , IDENT , "{" , [ field_init_list ] , "}" ;
send_expr       = "send" , expr , "." , IDENT , call_args ;
ask_expr        = "ask" , expr , "." , IDENT , call_args ;

(* ========================================================================= *)
(* Patterns                                                                   *)
(* ========================================================================= *)

pattern         = wildcard_pat | literal_pat | binding_pat | variant_pat ;
wildcard_pat    = "_" ;
literal_pat     = literal ;
binding_pat     = IDENT ;
variant_pat     = IDENT , [ variant_pat_payload ] ;
variant_pat_payload
                = "{" , [ pat_field_list ] , "}"
                | "(" , pattern , { "," , pattern } , ")" ;
pat_field_list  = pat_field , { "," , pat_field } , [ "," ] ;
pat_field       = IDENT , ":" , pattern ;

(* ========================================================================= *)
(* Literals                                                                   *)
(* ========================================================================= *)

literal         = INT_LIT | FLOAT_LIT | STRING_LIT | BOOL_LIT | "unit" ;
BOOL_LIT        = "true" | "false" ;

(* Integer literals may carry a type suffix: 42i32, 7u64, etc. Default i32.   *)
(* Float literals always contain a "." or "e". Default f64.                    *)
(* String literals are double-quoted UTF-8 with C-style escapes.               *)

(* ========================================================================= *)
(* Lexical                                                                    *)
(* ========================================================================= *)

IDENT           = ( letter | "_" ) , { letter | digit | "_" } ;
letter          = "a" | ... | "z" | "A" | ... | "Z" ;
digit           = "0" | ... | "9" ;

(* Line comments: // to end of line.                                          *)
(* Block comments: /* ... */ with nesting support.                             *)
(* Whitespace is insignificant except as a token separator.                    *)
(* Semicolons are NOT used — the parser uses braces for structure.             *)

(* ========================================================================= *)
(* Reserved keywords                                                          *)
(* ========================================================================= *)

(* fn let var type import if else match for in return as extern                *)
(* actor msg spawn send ask true false unit                                    *)
(*                                                                             *)
(* Contextual keywords (lex as IDENT, recognized positionally):                *)
(*   io, pure — effect annotations after fn return type                        *)
(*   link     — C symbol name after extern fn return type                      *)
