import std/io

type Shape =
    | Circle { radius: i32 }
    | Rectangle { width: i32, height: i32 }

fn approx_area(s: Shape): i32 {
    match s {
        Circle { radius: r } => 3 * r * r,
        Rectangle { width: w, height: h } => w * h,
    }
}

fn main(): i32 io {
    let c = Circle { radius: 5 }
    let r = Rectangle { width: 4, height: 6 }

    io.println("circle area ~ " + int.to_string_i32(approx_area(c)))
    io.println("rect area   = " + int.to_string_i32(approx_area(r)))
    0
}
