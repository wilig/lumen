import std/io
import std/int

fn sum_of_squares(n: i32): i32 {
    var total: i32 = 0
    for i in range(1, n + 1) {
        total = total + i * i
    }
    return total
}

fn main(): i32 io {
    let result = sum_of_squares(10)
    io.println("sum of squares 1..10 = " + int.to_string_i32(result))
    return 0
}
