import std/io
import std/int

fn divide(a: i32, b: i32): Result<i32, string> {
    return if b == 0 {
        Err("division by zero")
    } else {
        Ok(a / b)
    }
}

fn compute(): Result<i32, string> {
    let x = divide(100, 5)?
    let y = divide(x, 0)?
    return Ok(x + y)
}

fn main(): Result<i32, string> io {
    let result = compute()?
    io.println("result = " + int.to_string_i32(result))
    return Ok(0)
}
