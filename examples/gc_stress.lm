// Stress test: without GC, this would exhaust the 1MB heap.
// Each iteration of the loop builds a temporary string via concat
// that gets reclaimed when the helper function returns.

import std/io

fn format_line(i: i32): string {
    return "iteration " + int.to_string_i32(i) + " of 100000"
}

fn main(): i32 io {
    var last: string = ""
    for i in range(0, 100000) {
        last = format_line(i)
    }
    io.println(last)
    return 0
}
